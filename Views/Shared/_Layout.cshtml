<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sabor & Arte</title>
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <style>
        /* Animação para o Alerta Personalizado */
        @@keyframes popIn {
            0% { transform: scale(0.8); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }
    </style>
</head>
<body>

    <header style="background-color: var(--bg-card); padding: 15px 0; border-bottom: 1px solid #2a3454; position: sticky; top: 0; z-index: 100;">
        <div class="container" style="display: flex; justify-content: space-between; align-items: center;">
            
            <div style="color: var(--gold); font-size: 1.6rem; font-weight: bold; cursor: pointer;" onclick="window.location.href='/'">
                <span style="margin-right: 8px;">🍴</span> Sabor & Arte
            </div>

            <nav style="display: flex; gap: 30px;">
                <a href="#cardapio" style="color: white; text-decoration: none; font-weight: 500;">Cardápio</a>
                <a href="#pedidos" style="color: white; text-decoration: none; font-weight: 500;">Fazer Pedido</a>
                <a href="#reservas" style="color: white; text-decoration: none; font-weight: 500;">Reservar Mesa</a>
            </nav>

            <div class="auth-buttons">
                @if (!User.Identity.IsAuthenticated)
                {
                    <button onclick="abrirModalLogin()" class="btn-outline-gold" style="margin-right: 10px; padding: 8px 20px;">Entrar</button>
                    <button onclick="abrirModal()" class="btn-gold" style="padding: 8px 20px;">Cadastrar</button>
                }
                else
                {
                    <div style="display: flex; align-items: center; gap: 15px;">
                        <span style="color: var(--gold); cursor: pointer;" onclick="abrirPerfil()">
                            Olá, <strong style="text-decoration: underline;">@User.Identity.Name</strong>
                        </span>
                        <form asp-controller="Conta" asp-action="Logout" method="post" style="display: inline;">
                            <button type="submit" class="btn-outline-gold" style="padding: 5px 15px; font-size: 0.8rem;">Sair</button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer style="background-color: var(--bg-card); padding: 40px 0; border-top: 1px solid #2a3454; margin-top: 50px;">
        <div class="container" style="text-align: center; color: var(--text-gray);">
            <p style="margin-bottom: 10px; color: var(--gold); font-weight: bold;">Sabor & Arte</p>
            <p>&copy; 2026 - Restaurante Gourmet - Todos os direitos reservados.</p>
        </div>
    </footer>

    <div id="customAlertModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.85); z-index: 99999; justify-content: center; align-items: center; backdrop-filter: blur(5px);">
        <div style="background: #1e293b; border-radius: 12px; width: 90%; max-width: 400px; border: 1px solid var(--gold); padding: 30px; text-align: center; box-shadow: 0 10px 25px rgba(0,0,0,0.5); animation: popIn 0.3s ease-out;">
            <div id="customAlertIcon" style="width: 60px; height: 60px; border-radius: 50%; background: rgba(212, 175, 55, 0.2); display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
                <span style="font-size: 30px;">⚠️</span>
            </div>
            <h3 id="customAlertTitle" style="color: var(--gold); margin-bottom: 15px; font-size: 1.5rem;">Aviso</h3>
            <p id="customAlertMensagem" style="color: white; font-size: 1.05rem; margin-bottom: 25px; line-height: 1.5; white-space: pre-wrap;"></p>
            <button onclick="fecharAlertaPersonalizado()" class="btn-gold" style="width: 100%; padding: 12px; border-radius: 8px; font-weight: bold; border: none; cursor: pointer;">Entendi</button>
        </div>
    </div>

    <div id="customConfirmModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.9); z-index: 999999; justify-content: center; align-items: center; backdrop-filter: blur(5px);">
        <div style="background: #1e293b; border-radius: 12px; width: 95%; max-width: 400px; border: 1px solid var(--gold); padding: 30px; text-align: center; animation: popIn 0.3s ease-out;">
            <div style="font-size: 40px; margin-bottom: 15px;">❓</div>
            <h3 style="color: var(--gold); margin-bottom: 15px;">Confirmar Ação</h3>
            <p id="confirmMessage" style="color: white; margin-bottom: 25px; line-height: 1.5;"></p>
            <div style="display: flex; gap: 10px;">
                <button id="btnConfirmSim" class="btn-gold" style="flex: 1; padding: 12px; border-radius: 8px; font-weight: bold; border: none; cursor: pointer;">Sim, confirmar</button>
                <button onclick="fecharConfirmacao()" class="btn-outline-gold" style="flex: 1; padding: 12px; border-radius: 8px; font-weight: bold; cursor: pointer; background: rgba(255,255,255,0.05);">Cancelar</button>
            </div>
        </div>
    </div>

    <div id="modalLogin" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.9); z-index: 1001; justify-content: center; align-items: center; backdrop-filter: blur(8px);">
        <div class="modal-content-panel">
            <button onclick="fecharModalLogin()" class="modal-close-btn">&times;</button>
            <h2 class="modal-title">Entrar</h2>
            <form asp-controller="Conta" asp-action="Login" method="post">
                <div class="form-group">
                    <label>Nome de Usuário</label>
                    <input name="NomeUsuario" type="text" class="form-input" required placeholder="Digite seu usuário">
                </div>
                <div class="form-group" style="margin-bottom: 5px;">
                    <label>Senha</label>
                    <input name="Senha" type="password" class="form-input" required placeholder="Digite sua senha">
                </div>
                <a href="#" onclick="abrirModalRecuperacao()" style="color: var(--gold); font-size: 0.85rem; display: block; text-align: right; margin-bottom: 20px; text-decoration: none;">Esqueceu a senha?</a>
                
                <button type="submit" class="btn-finalizar">Entrar</button>
            </form>
        </div>
    </div>

    <div id="modalCadastro" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.9); z-index: 1000; justify-content: center; align-items: center; backdrop-filter: blur(8px);">
        <div class="modal-content-panel">
            <button onclick="fecharModal()" class="modal-close-btn">&times;</button>
            <h2 class="modal-title">Criar Conta</h2>
            
            <form id="formCadastro" autocomplete="off" onsubmit="enviarCadastroAjax(event)">
                <input type="text" style="display:none">
                <input type="password" style="display:none">

                <div class="form-row">
                    <div class="form-group">
                        <label>Nome</label>
                        <input name="Nome" type="text" class="form-input" autocomplete="new-password" required>
                    </div>
                    <div class="form-group">
                        <label>Sobrenome</label>
                        <input name="Sobrenome" type="text" class="form-input" autocomplete="new-password" required>
                    </div>
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label>E-mail</label>
                        <input name="Email" type="email" class="form-input" placeholder="exemplo@email.com" autocomplete="new-password" required>
                    </div>
                    <div class="form-group">
                        <label>Telefone (Só números)</label>
                        <input name="Telefone" type="text" class="form-input" placeholder="Ex: 63999999999" maxlength="11" oninput="this.value = this.value.replace(/[^0-9]/g, '')" autocomplete="new-password" required>
                    </div>
                </div>

                <div class="form-group">
                    <label>Nome de Usuário</label>
                    <input name="NomeUsuario" type="text" class="form-input" autocomplete="new-password" required>
                </div>
                <div class="form-group">
                    <label>CPF (Só números)</label>
                    <input name="CPF" type="text" class="form-input" placeholder="Ex: 12345678901" maxlength="11" oninput="this.value = this.value.replace(/[^0-9]/g, '')" autocomplete="new-password" required>
                </div>
                <div class="form-group">
                    <label>Senha</label>
                    <input name="Senha" type="password" class="form-input" autocomplete="new-password" required>
                    <small style="color: var(--text-gray); font-size: 0.75rem; display: block; margin-top: 5px;">A senha deve ter no mínimo 6 caracteres, 1 maiúscula, 1 minúscula e 1 número.</small>
                </div>
                <div class="form-group">
                    <label>Confirmar Senha</label>
                    <input name="ConfirmarSenha" type="password" class="form-input" autocomplete="new-password" required>
                </div>
                <button type="submit" class="btn-finalizar">Finalizar Cadastro</button>
            </form>
        </div>
    </div>

    <div id="modalRecuperarSenha" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.9); z-index: 1002; justify-content: center; align-items: center; backdrop-filter: blur(8px);">
        <div class="modal-content-panel" style="max-height: 90vh; overflow-y: auto;">
            <button onclick="fecharModalRecuperacao()" class="modal-close-btn">&times;</button>
            <h2 class="modal-title">Recuperar Conta</h2>
            <p style="color: var(--text-gray); font-size: 0.9rem; text-align: center; margin-bottom: 20px;">
                Preencha seus dados corretamente para provar sua identidade e cadastrar uma nova senha.
            </p>
            
            <form id="formRecuperacao" autocomplete="off" onsubmit="enviarRecuperacaoAjax(event)">
                <div class="form-row">
                    <div class="form-group">
                        <label>Nome Registrado</label>
                        <input name="Nome" type="text" class="form-input" required>
                    </div>
                    <div class="form-group">
                        <label>Sobrenome Registrado</label>
                        <input name="Sobrenome" type="text" class="form-input" required>
                    </div>
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label>E-mail Registrado</label>
                        <input name="Email" type="email" class="form-input" required>
                    </div>
                    <div class="form-group">
                        <label>Telefone (Só números)</label>
                        <input name="Telefone" type="text" class="form-input" maxlength="11" oninput="this.value = this.value.replace(/[^0-9]/g, '')" required>
                    </div>
                </div>

                <div class="form-group">
                    <label>CPF (Só números)</label>
                    <input name="CPF" type="text" class="form-input" maxlength="11" oninput="this.value = this.value.replace(/[^0-9]/g, '')" required>
                </div>

                <hr style="border-color: rgba(255,255,255,0.1); margin: 20px 0;" />
                
                <div class="form-group">
                    <label>Novo Nome de Usuário <span style="color: var(--text-gray); font-size: 0.8rem;">(Deixe em branco para não alterar)</span></label>
                    <input name="NovoNomeUsuario" type="text" class="form-input">
                </div>

                <div class="form-group">
                    <label>Nova Senha</label>
                    <input name="NovaSenha" type="password" class="form-input" required>
                    <small style="color: var(--text-gray); font-size: 0.75rem; display: block; margin-top: 5px;">A senha deve ter no mínimo 6 caracteres, 1 maiúscula, 1 minúscula e 1 número.</small>
                </div>
                <div class="form-group">
                    <label>Confirmar Nova Senha</label>
                    <input name="ConfirmarNovaSenha" type="password" class="form-input" required>
                </div>

                <button type="submit" class="btn-finalizar">Redefinir e Logar</button>
            </form>
        </div>
    </div>

    <div id="enderecoModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.9); z-index: 1060; justify-content: center; align-items: center; backdrop-filter: blur(8px);">
        <div class="modal-content-panel" style="max-width: 500px;">
            <button onclick="fecharModalEndereco()" class="modal-close-btn">&times;</button>
            <h2 class="modal-title" id="tituloModalEnd">Novo Endereço</h2>
            
            <form id="formEnd" onsubmit="salvarEndereco(event)">
                <input type="hidden" id="endId">
                
                <div class="form-group">
                    <label>CEP <span style="color: var(--gold); font-size: 0.8rem;">(Digite para autocompletar)</span></label>
                    <input type="text" id="endCep" class="form-input" placeholder="77000-000" maxlength="8" oninput="this.value = this.value.replace(/[^0-9]/g, ''); if(this.value.length === 8) buscarCepNaApi();" required>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Quadra / ARSE / ARSO</label>
                        <input type="text" id="endQuadra" class="form-input" placeholder="Ex: 104 Sul" required>
                    </div>
                    <div class="form-group">
                        <label>Alameda / QI</label>
                        <input type="text" id="endAlameda" class="form-input" placeholder="Ex: Alameda 02" required>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Lote</label>
                        <input type="text" id="endLote" class="form-input" placeholder="Ex: 14" required>
                    </div>
                    <div class="form-group">
                        <label>Complemento</label>
                        <input type="text" id="endComplemento" class="form-input" placeholder="Apt, Bloco, Casa (Opcional)">
                    </div>
                </div>

                <div class="form-group">
                    <label>Ponto de Referência</label>
                    <input type="text" id="endReferencia" class="form-input" placeholder="Perto de onde?" required>
                </div>
                
                <button type="submit" class="btn-finalizar">Salvar Endereço</button>
            </form>
        </div>
    </div>

    <div id="itemCardapioModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.9); z-index: 1060; justify-content: center; align-items: center; backdrop-filter: blur(8px);">
        <div class="modal-content-panel" style="max-width: 500px;">
            <button onclick="fecharModalItemCardapio()" class="modal-close-btn">&times;</button>
            <h2 class="modal-title" id="tituloModalItem">Novo Item do Cardápio</h2>
            
            <form id="formItemCardapio" onsubmit="salvarItemCardapio(event)">
                <input type="hidden" id="itemId">
                <input type="hidden" id="itemImagemUrlAntiga"> 
                
                <div class="form-group">
                    <label>Nome do Prato</label>
                    <input type="text" id="itemNome" class="form-input" required>
                </div>
                <div class="form-group">
                    <label>Descrição</label>
                    <textarea id="itemDescricao" class="form-input" rows="3" required style="resize: vertical;"></textarea>
                </div>
                
                <div class="form-group">
                    <label>Foto do Prato</label>
                    <input type="file" id="itemImagemArquivo" class="form-input" accept="image/*">
                    <small id="textoImagemAtual" style="color: var(--gold); display: block; margin-top: 5px; font-weight: bold;"></small> 
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Preço Base (R$)</label>
                        <input type="number" step="0.01" id="itemPreco" class="form-input" required>
                    </div>
                    <div class="form-group">
                        <label>Período</label>
                        <select id="itemPeriodo" class="form-input" required>
                            <option value="0">Almoço</option>
                            <option value="1">Jantar</option>
                        </select>
                    </div>
                </div>
                
                <div class="form-group" style="margin-top: 15px;">
                    <label>Ingredientes do Prato</label>
                    <div style="display: flex; gap: 10px; margin-bottom: 10px;">
                        <input type="text" id="novoIngredienteNome" class="form-input" placeholder="Novo ingrediente..." style="flex: 1;">
                        <button type="button" onclick="salvarNovoIngrediente()" class="btn-outline-gold" style="padding: 0 15px; white-space: nowrap;">+ Criar</button>
                    </div>
                    
                    <div id="listaIngredientesVisual" style="max-height: 150px; overflow-y: auto; border: 1px solid var(--border-color); padding: 5px 10px; border-radius: 5px; background: rgba(15, 23, 42, 0.5);">
                        <p style="color: var(--text-gray); font-size: 0.85rem; margin: 5px 0;">Carregando ingredientes...</p>
                    </div>
                </div>

                <button type="submit" class="btn-finalizar">Salvar Prato</button>
            </form>
        </div>
    </div>

    <div id="perfilModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); z-index: 1050; justify-content: center; align-items: center; backdrop-filter: blur(5px);">
        <div style="background: var(--bg-card); border-radius: 15px; width: 90%; max-width: 1000px; height: 80vh; display: flex; overflow: hidden; border: 1px solid rgba(212,175,55,0.2); position: relative;">
            
            <button onclick="fecharPerfil()" class="modal-close-btn" style="top: 15px; right: 20px;">&times;</button>

            <div style="width: 250px; background: rgba(15, 23, 42, 0.5); padding: 40px 20px; border-right: 1px solid rgba(255,255,255,0.05);">
                <h2 style="color: var(--gold); margin-bottom: 40px; font-size: 1.5rem;">Meu Perfil</h2>
                
                <nav style="display: flex; flex-direction: column; gap: 10px;">
                    <button id="btnAbaDados" onclick="carregarAba('Dados')" class="perfil-nav-btn active">Meus Dados</button>

                    @if (!User.IsInRole("Admin"))
                    {
                        <button id="btnAbaEnderecos" onclick="carregarAba('Enderecos')" class="perfil-nav-btn">Endereços</button>
                        <button id="btnAbaPedidos" onclick="carregarAba('Pedidos')" class="perfil-nav-btn">Meus Pedidos</button>
                        <button id="btnAbaReservas" onclick="carregarAba('Reservas')" class="perfil-nav-btn">Minhas Reservas</button>
                    }

                    <button id="btnAbaConfig" onclick="carregarAba('Config')" class="perfil-nav-btn">Configurações</button>

                    @if (User.IsInRole("Admin"))
                    {
                        <hr style="border-color: rgba(255,255,255,0.1); margin: 15px 0;" />
                        <span style="color: var(--text-gray); font-size: 0.8rem; text-transform: uppercase;">Administração</span>
                        
                        <button id="btnAbaPratos" onclick="carregarAba('Pratos')" class="perfil-nav-btn" style="color: #ffb703;">Gerenciar Pratos</button>
                        <button id="btnAbaSugestoes" onclick="carregarAba('Sugestoes')" class="perfil-nav-btn" style="color: #ffb703;">Sugestão do Chefe</button>
                        <button id="btnAbaUsuarios" onclick="carregarAba('Usuarios')" class="perfil-nav-btn" style="color: #ffb703;">Gerenciar Usuários</button>
                        <button id="btnAbaRelatorios" onclick="carregarAba('Relatorios')" class="perfil-nav-btn" style="color: #ffb703;">Relatórios</button>
                    }
                </nav>
            </div>

            <div id="perfilContent" style="flex: 1; padding: 40px; overflow-y: auto; background: #1e293b;">
                <div style="display: flex; justify-content: center; align-items: center; height: 100%;">
                    <p style="color: var(--text-gray);">Carregando informações...</p>
                </div>
            </div>
        </div>
    </div>

    <div id="modalNovoEnderecoPedido" style="display: none;"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        // ========================================================
        // 1. SISTEMA DE ALERTAS E CONFIRMAÇÕES (UI PERSONALIZADA)
        // ========================================================
        window.alert = function(msg) {
            const modal = document.getElementById('customAlertModal');
            const mensagemTexto = document.getElementById('customAlertMensagem');
            const title = document.getElementById('customAlertTitle');
            const icon = document.getElementById('customAlertIcon');

            mensagemTexto.innerText = msg;
            
            if(msg.toLowerCase().includes("sucesso") || msg.toLowerCase().includes("certo")) {
                title.innerText = "Tudo Certo!";
                title.style.color = "#22c55e";
                icon.innerHTML = "✔️";
                icon.style.background = "rgba(34, 197, 94, 0.2)";
            } else {
                title.innerText = "Atenção";
                title.style.color = "var(--gold)";
                icon.innerHTML = "⚠️";
                icon.style.background = "rgba(212, 175, 55, 0.2)";
            }
            modal.style.display = 'flex';
        };

        let callbackConfirmacaoGlobal = null;
        function perguntar(mensagem, callback) {
            document.getElementById('confirmMessage').innerText = mensagem;
            document.getElementById('customConfirmModal').style.display = 'flex';
            callbackConfirmacaoGlobal = callback;
        }

        document.getElementById('btnConfirmSim').onclick = function() {
            if (callbackConfirmacaoGlobal) callbackConfirmacaoGlobal();
            fecharConfirmacao();
        };

        function fecharAlertaPersonalizado() {
            document.getElementById('customAlertModal').style.display = 'none';
        }

        function fecharConfirmacao() {
            document.getElementById('customConfirmModal').style.display = 'none';
            callbackConfirmacaoGlobal = null;
        }

        // ========================================================
        // 2. ATUALIZAÇÃO AUTOMÁTICA DE PEDIDOS E RELATÓRIOS (20s)
        // ========================================================
        setInterval(function() {
            const modalPerfil = document.getElementById('perfilModal');
            
            if (modalPerfil && modalPerfil.style.display === 'flex') {
                const abaPedidosAtiva = document.getElementById('btnAbaPedidos')?.classList.contains('active');
                const abaRelatoriosAtiva = document.getElementById('btnAbaRelatorios')?.classList.contains('active');

                if (abaPedidosAtiva) {
                    carregarAba('Pedidos');
                } else if (abaRelatoriosAtiva) {
                    carregarAba('Relatorios');
                }
            }
        }, 20000); 

        // ========================================================
        // 3. LÓGICA DE VALIDAÇÃO DE SEGURANÇA (SENHA)
        // ========================================================
        function validarForcaDaSenha(senha) {
            const regexMaiuscula = /[A-Z]/;
            const regexMinuscula = /[a-z]/;
            const regexNumero = /[0-9]/;
            
            if (senha.length < 6) return "A senha deve ter no mínimo 6 caracteres.";
            if (!regexMaiuscula.test(senha)) return "A senha deve conter pelo menos uma letra maiúscula.";
            if (!regexMinuscula.test(senha)) return "A senha deve conter pelo menos uma letra minúscula.";
            if (!regexNumero.test(senha)) return "A senha deve conter pelo menos um número.";
            
            return null; 
        }

        // ========================================================
        // 4. COMUNICAÇÃO AJAX (CADASTRO E RECUPERAÇÃO)
        // ========================================================
        function enviarCadastroAjax(event) {
            event.preventDefault(); 
            const form = document.getElementById('formCadastro');
            const senha = form.querySelector('[name="Senha"]').value;
            const confirmar = form.querySelector('[name="ConfirmarSenha"]').value;

            if (senha !== confirmar) {
                alert("As senhas que você digitou não coincidem! Por favor, verifique e digite novamente.");
                return;
            }

            const erroSenha = validarForcaDaSenha(senha);
            if (erroSenha) {
                alert(erroSenha);
                return;
            }

            const payload = {
                Nome: form.querySelector('[name="Nome"]').value,
                Sobrenome: form.querySelector('[name="Sobrenome"]').value,
                Email: form.querySelector('[name="Email"]').value,
                Telefone: form.querySelector('[name="Telefone"]').value,
                NomeUsuario: form.querySelector('[name="NomeUsuario"]').value,
                CPF: form.querySelector('[name="CPF"]').value,
                Senha: senha,
                ConfirmarSenha: confirmar
            };

            fetch('/Conta/Cadastrar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            }).then(async res => {
                if (res.ok) {
                    fecharModal(); 
                    window.location.reload(); 
                } else {
                    const txt = await res.text();
                    try {
                        const obj = JSON.parse(txt);
                        alert(obj.mensagem || "Verifique os dados informados e tente novamente.");
                    } catch {
                        alert(txt || "Falha na comunicação com o servidor ao processar o cadastro.");
                    }
                }
            }).catch(err => alert("Não foi possível conectar ao servidor. Verifique sua conexão."));
        }

        function enviarRecuperacaoAjax(event) {
            event.preventDefault();

            const form = document.getElementById('formRecuperacao');
            const novaSenha = form.querySelector('[name="NovaSenha"]').value;
            const confirmarNova = form.querySelector('[name="ConfirmarNovaSenha"]').value;

            if (novaSenha !== confirmarNova) {
                alert("As senhas que você digitou não coincidem!");
                return;
            }

            const erroSenha = validarForcaDaSenha(novaSenha);
            if (erroSenha) {
                alert(erroSenha);
                return;
            }

            const payload = {
                Nome: form.querySelector('[name="Nome"]').value,
                Sobrenome: form.querySelector('[name="Sobrenome"]').value,
                Email: form.querySelector('[name="Email"]').value,
                Telefone: form.querySelector('[name="Telefone"]').value,
                CPF: form.querySelector('[name="CPF"]').value,
                NovoNomeUsuario: form.querySelector('[name="NovoNomeUsuario"]').value,
                NovaSenha: novaSenha,
                ConfirmarNovaSenha: confirmarNova
            };

            fetch('/Conta/ResetarSenha', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            }).then(async res => {
                if (res.ok) {
                    fecharModalRecuperacao();
                    window.location.reload(); 
                } else {
                    const txt = await res.text();
                    try {
                        const obj = JSON.parse(txt);
                        alert(obj.mensagem || "Verifique os dados informados.");
                    } catch {
                        alert(txt || "Falha na comunicação com o servidor ao redefinir a senha.");
                    }
                }
            }).catch(err => alert("Não foi possível conectar ao servidor. Verifique sua conexão."));
        }

        // ========================================================
        // 5. FUNÇÕES DE ENDEREÇO (VIACEP E CRUD)
        // ========================================================
        function buscarCepNaApi() {
            const cep = document.getElementById('endCep').value;
            if (cep.length === 8) {
                fetch(`https://viacep.com.br/ws/${cep}/json/`)
                    .then(res => res.json())
                    .then(data => {
                        if (!data.erro) {
                            document.getElementById('endQuadra').value = data.bairro || '';
                            document.getElementById('endAlameda').value = data.logradouro || '';
                            document.getElementById('endLote').focus();
                        } else {
                            alert("Atenção: O CEP informado não foi encontrado.");
                        }
                    })
                    .catch(() => alert("Erro ao buscar o CEP na internet."));
            }
        }

        function abrirModalEndereco(id = null, cep = '', quadra = '', alameda = '', lote = '', comp = '', ref = '') {
            document.getElementById('endId').value = id || '';
            document.getElementById('endCep').value = cep;
            document.getElementById('endQuadra').value = quadra;
            document.getElementById('endAlameda').value = alameda;
            document.getElementById('endLote').value = lote;
            document.getElementById('endComplemento').value = comp;
            document.getElementById('endReferencia').value = ref;
            
            document.getElementById('tituloModalEnd').innerText = id ? 'Editar Endereço' : 'Novo Endereço';
            document.getElementById('enderecoModal').style.display = 'flex';
        }

        function fecharModalEndereco() {
            document.getElementById('enderecoModal').style.display = 'none';
        }

        function salvarEndereco(e) {
            e.preventDefault();
            
            const model = {
                Id: document.getElementById('endId').value ? parseInt(document.getElementById('endId').value) : null,
                CEP: document.getElementById('endCep').value,
                Quadra: document.getElementById('endQuadra').value,
                Alameda: document.getElementById('endAlameda').value,
                Lote: document.getElementById('endLote').value,
                Complemento: document.getElementById('endComplemento').value,
                Referencia: document.getElementById('endReferencia').value
            };

            fetch('/Conta/SalvarEndereco', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(model)
            }).then(async res => {
                if (res.ok) {
                    const data = await res.json();
                    alert(data.mensagem || "Sucesso! Endereço salvo.");
                    fecharModalEndereco();
                    carregarAba('Enderecos');
                } else {
                    const txt = await res.text();
                    try {
                        const obj = JSON.parse(txt);
                        alert(obj.mensagem || "Verifique os campos do endereço.");
                    } catch {
                        alert("Erro ao processar a validação do endereço no servidor.");
                    }
                }
            }).catch(() => alert("Não foi possível conectar ao servidor para salvar o endereço."));
        }

        function removerEndereco(id) {
            perguntar("Deseja remover este endereço?", function() {
                fetch('/Conta/RemoverEndereco/' + id, { method: 'POST' })
                    .then(() => carregarAba('Enderecos'));
            });
        }

        // ========================================================
        // 6. MODAIS GERAIS (LOGIN E PERFIL)
        // ========================================================
        function abrirModal() { 
            fecharModalLogin();
            document.getElementById('modalCadastro').style.display = 'flex'; 
        }
        function fecharModal() { document.getElementById('modalCadastro').style.display = 'none'; }

        function abrirModalLogin() { document.getElementById('modalLogin').style.display = 'flex'; }
        function fecharModalLogin() { document.getElementById('modalLogin').style.display = 'none'; }

        function abrirModalRecuperacao() {
            fecharModalLogin();
            document.getElementById('modalRecuperarSenha').style.display = 'flex';
        }
        function fecharModalRecuperacao() { document.getElementById('modalRecuperarSenha').style.display = 'none'; }

        function abrirPerfil() {
            document.getElementById('perfilModal').style.display = 'flex';
            carregarAba(document.getElementById('btnAbaDados') ? 'Dados' : 'Pratos');
        }
        function fecharPerfil() { document.getElementById('perfilModal').style.display = 'none'; }

        function carregarAba(aba) {
            $(".perfil-nav-btn").removeClass("active");
            const btn = document.getElementById(`btnAba${aba}`);
            if (btn) btn.classList.add("active");
            
            const map = { 
                'Dados': '/Conta/ObterDadosPerfil', 
                'Enderecos': '/Conta/ObterEnderecos', 
                'Pratos': '/Admin/ObterItensCardapio', 
                'Sugestoes': '/Admin/ObterSugestoes',
                'Usuarios': '/Admin/ObterUsuarios',
                'Relatorios': '/Admin/ObterRelatorios',
                'Pedidos': '/Pedido/ObterMeusPedidos',
                'Reservas': '/Reserva/ObterMinhasReservas'
            };

            if(map[aba]) {
                $("#perfilContent").html('<p style="color: white; text-align:center;">Carregando...</p>');
                $("#perfilContent").load(map[aba]);
            }
        }

        window.carregarMeusPedidos = function() {
            carregarAba('Pedidos');
        }

        // ========================================================
        // 7. CANCELAMENTO E EXCLUSÃO DE CONTAS
        // ========================================================
        function cancelarReserva(id, dataReservaStr) {
            const dataReserva = new Date(dataReservaStr);
            const agora = new Date();
            
            const horasDiferenca = (dataReserva - agora) / (1000 * 60 * 60);
            let msgConfirmacao = "Tem certeza que deseja cancelar esta reserva?";
            
            if (horasDiferenca < 6) {
                msgConfirmacao = "ATENÇÃO: Faltam menos de 6 horas para a sua reserva!\n\nDe acordo com as nossas políticas, será cobrada uma multa de R$ 50,00 pelo cancelamento tardio.\n\nDeseja cancelar mesmo assim?";
            }

            perguntar(msgConfirmacao, function() {
                fetch('/Reserva/CancelarReserva/' + id, { method: 'POST' })
                .then(async res => {
                    if (res.ok) {
                        const data = await res.json();
                        alert(data.mensagem); 
                        carregarAba('Reservas'); 
                    } else {
                        alert(await res.text());
                    }
                });
            });
        }

        function desativarMinhaConta() {
            perguntar("ATENÇÃO: Tem certeza absoluta que deseja desativar sua conta? Você será desconectado imediatamente.", function() {
                fetch('/Conta/DesativarConta', { method: 'POST' })
                .then(async response => {
                    if(response.ok) {
                        window.location.href = '/';
                    } else {
                        const msg = await response.text();
                        alert(msg || "Erro ao tentar desativar a conta.");
                    }
                }).catch(() => {
                    alert("Erro de conexão com o servidor.");
                });
            });
        }

        // ========================================================
        // 8. CARDÁPIO E INGREDIENTES (ADMINISTRADOR)
        // ========================================================
        let ingredientesChecadosGlobal = [];

        function carregarIngredientesNoSelect(idsSelecionados = []) {
            ingredientesChecadosGlobal = idsSelecionados;
            
            fetch('/Admin/ObterIngredientes')
                .then(response => response.json())
                .then(data => {
                    const container = document.getElementById('listaIngredientesVisual');
                    container.innerHTML = '';
                    
                    if(data.length === 0) {
                        container.innerHTML = '<p style="color: var(--text-gray); font-size: 0.85rem; margin: 5px 0;">Nenhum ingrediente cadastrado.</p>';
                        return;
                    }

                    data.forEach(ing => {
                        const isChecked = ingredientesChecadosGlobal.includes(ing.id) ? 'checked' : '';
                        
                        if (ing.isAtivo) {
                            container.innerHTML += `
                                <div class="ingrediente-row" id="ing-row-${ing.id}" style="display: flex; justify-content: space-between; align-items: center; padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,0.05);">
                                    <label style="display: flex; align-items: center; gap: 10px; margin: 0; cursor: pointer; flex: 1;">
                                        <input type="checkbox" class="ing-checkbox" value="${ing.id}" ${isChecked} onchange="atualizarChecados(this)">
                                        <span id="ing-nome-${ing.id}" style="color: white; font-size: 0.9rem;">${ing.nome}</span>
                                    </label>
                                    <div id="ing-acoes-${ing.id}" style="display: flex; gap: 8px;">
                                        <button type="button" onclick="habilitarEdicaoIngrediente(${ing.id}, '${ing.nome.replace("'", "\\'")}')" style="background: none; border: none; cursor: pointer; filter: grayscale(100%); transition: 0.3s;" onmouseover="this.style.filter='none'" onmouseout="this.style.filter='grayscale(100%)'" title="Editar">✏️</button>
                                        <button type="button" onclick="alternarStatusIngrediente(${ing.id}, false)" style="background: none; border: none; cursor: pointer; filter: grayscale(100%); transition: 0.3s;" onmouseover="this.style.filter='none'" onmouseout="this.style.filter='grayscale(100%)'" title="Desativar">❌</button>
                                    </div>
                                </div>
                            `;
                        } else {
                            container.innerHTML += `
                                <div class="ingrediente-row" id="ing-row-${ing.id}" style="display: flex; justify-content: space-between; align-items: center; padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,0.05); opacity: 0.5;">
                                    <div style="display: flex; align-items: center; gap: 10px; margin: 0; flex: 1;">
                                        <span style="display: inline-block; width: 13px; height: 13px; border: 1px solid #ef4444; border-radius: 3px; background: rgba(239,68,68,0.2);"></span>
                                        <span id="ing-nome-${ing.id}" style="color: #ef4444; font-size: 0.9rem; text-decoration: line-through;">${ing.nome} (Desativado)</span>
                                    </div>
                                    <div id="ing-acoes-${ing.id}" style="display: flex; gap: 8px;">
                                        <button type="button" onclick="alternarStatusIngrediente(${ing.id}, true)" class="btn-outline-gold" style="padding: 2px 8px; font-size: 0.7rem;">Ativar</button>
                                    </div>
                                </div>
                            `;
                        }
                    });
                });
        }

        function atualizarChecados(checkbox) {
            const id = parseInt(checkbox.value);
            if(checkbox.checked) {
                if(!ingredientesChecadosGlobal.includes(id)) ingredientesChecadosGlobal.push(id);
            } else {
                ingredientesChecadosGlobal = ingredientesChecadosGlobal.filter(i => i !== id);
            }
        }

        function habilitarEdicaoIngrediente(id, nomeAtual) {
            const spanNome = document.getElementById(`ing-nome-${id}`);
            const divAcoes = document.getElementById(`ing-acoes-${id}`);

            spanNome.innerHTML = `<input type="text" id="input-edit-${id}" value="${nomeAtual}" class="form-input" style="padding: 2px 5px; height: 28px; width: 150px; font-size: 0.85rem;">`;

            divAcoes.innerHTML = `
                <button type="button" onclick="salvarEdicaoIngrediente(${id})" style="background: none; border: none; cursor: pointer;" title="Salvar">💾</button>
                <button type="button" onclick="carregarIngredientesNoSelect(ingredientesChecadosGlobal)" style="background: none; border: none; cursor: pointer;" title="Cancelar">🚫</button>
            `;
        }

        function salvarEdicaoIngrediente(id) {
            const novoNome = document.getElementById(`input-edit-${id}`).value;
            if(!novoNome) return alert("O nome não pode ser vazio.");

            fetch(`/Admin/AtualizarIngrediente/${id}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ Nome: novoNome })
            }).then(response => {
                if(response.ok) carregarIngredientesNoSelect(ingredientesChecadosGlobal);
                else alert("Erro ao atualizar ingrediente.");
            });
        }

        function alternarStatusIngrediente(id, ativando) {
            const acao = ativando ? "ativar" : "desativar";
            perguntar(`Deseja ${acao} este ingrediente?`, function() {
                fetch(`/Admin/AlternarStatusIngrediente/${id}`, { method: 'POST' })
                    .then(response => {
                        if(response.ok) {
                            if (!ativando) {
                                ingredientesChecadosGlobal = ingredientesChecadosGlobal.filter(i => i !== id);
                            }
                            carregarIngredientesNoSelect(ingredientesChecadosGlobal);
                        }
                    });
            });
        }

        function salvarNovoIngrediente() {
            const nome = document.getElementById('novoIngredienteNome').value;
            if(!nome) return alert('Digite o nome do ingrediente.');

            fetch('/Admin/AdicionarIngredienteRapido', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(nome)
            })
            .then(response => response.json())
            .then(data => {
                ingredientesChecadosGlobal.push(data.id);
                carregarIngredientesNoSelect(ingredientesChecadosGlobal);
                document.getElementById('novoIngredienteNome').value = '';
            });
        }

        function confirmarTrocaStatusPrato(id, acao) {
            perguntar(`Deseja realmente ${acao} este prato do cardápio?`, function() {
                fetch(`/Admin/AlternarStatusPrato?id=${id}`, { method: 'POST' })
                    .then(async res => {
                        if (res.ok) {
                            const data = await res.json();
                            alert(data.mensagem);
                            
                            const filtroAtual = window.ultimoFiltroAplicado || 'ativos';
                            carregarAbaPratosFiltro(filtroAtual);
                            
                        } else {
                            const txt = await res.text();
                            alert("Não foi possível alterar o status: " + txt);
                        }
                    })
                    .catch(err => {
                        alert("Erro crítico: O navegador não conseguiu falar com o servidor.");
                    });
            });
        }

        function carregarAbaPratosFiltro(valorFiltro) {
            window.ultimoFiltroAplicado = valorFiltro;
            const container = $("#perfilContent");
            container.html('<p style="color: white; text-align:center; padding: 20px;">Atualizando lista...</p>');
            
            container.load(`/Admin/ObterItensCardapio?filtro=${valorFiltro}`, function(res, status, xhr) {
                if (status === "error") alert("Erro ao filtrar: " + xhr.status);
            });
        }

        function abrirModalItemCardapio(id = null, nome = '', desc = '', preco = '', periodo = '0', imagemUrl = '', ingredientesSelecionados = '[]') {
            document.getElementById('itemId').value = id || '';
            document.getElementById('itemNome').value = nome;
            document.getElementById('itemDescricao').value = desc;
            document.getElementById('itemPreco').value = preco;
            document.getElementById('itemPeriodo').value = periodo;
            
            document.getElementById('itemImagemUrlAntiga').value = imagemUrl; 
            const inputFile = document.getElementById('itemImagemArquivo');
            if (inputFile) inputFile.value = ''; 
            
            const textoImg = document.getElementById('textoImagemAtual');
            if (id && imagemUrl && imagemUrl !== '/sem-foto.png') {
                textoImg.innerHTML = `🖼️ Este prato já possui imagem. Só anexe um novo arquivo se quiser trocá-la.`;
            } else {
                textoImg.innerHTML = ``;
            }
        
            const idsParseados = JSON.parse(ingredientesSelecionados);
            carregarIngredientesNoSelect(idsParseados);
        
            document.getElementById('tituloModalItem').innerText = id ? 'Editar Prato' : 'Novo Prato';
            document.getElementById('itemCardapioModal').style.display = 'flex';
        }

        function fecharModalItemCardapio() {
            document.getElementById('itemCardapioModal').style.display = 'none';
        }

        function salvarItemCardapio(e) {
            e.preventDefault();

            const formData = new FormData();
            
            const id = document.getElementById('itemId').value;
            if(id) formData.append('Id', id);
            
            formData.append('Nome', document.getElementById('itemNome').value);
            formData.append('Descricao', document.getElementById('itemDescricao').value);
            formData.append('PrecoBase', document.getElementById('itemPreco').value.replace(',', '.'));
            formData.append('Periodo', document.getElementById('itemPeriodo').value);
            formData.append('ImagemUrl', document.getElementById('itemImagemUrlAntiga').value);

            ingredientesChecadosGlobal.forEach(ingId => {
                formData.append('IngredientesIds', ingId);
            });

            const fileInput = document.getElementById('itemImagemArquivo');
            if (fileInput && fileInput.files.length > 0) {
                formData.append('imagemArquivo', fileInput.files[0]);
            }

            fetch('/Admin/SalvarItemCardapio', {
                method: 'POST',
                body: formData 
            }).then(async (response) => {
                if (response.ok) {
                    fecharModalItemCardapio();
                    carregarAba('Pratos');
                } else {
                    const erroMsg = await response.text();
                    alert(erroMsg);
                }
            }).catch(error => {
                alert("Erro crítico de conexão com o servidor.");
            });
        }

        function removerItemCardapio(id) {
            perguntar("Deseja remover este prato do cardápio permanentemente?", function() {
                fetch('/Admin/RemoverItemCardapio/' + id, { method: 'POST' })
                    .then(() => carregarAba('Pratos'));
            });
        }

        // ========================================================
        // 9. FUNÇÕES EXTRAS DO ADMIN (SUGESTÕES E USUÁRIOS)
        // ========================================================
        function definirSugestaoManual(id) {
            fetch(`/Admin/DefinirSugestao?pratoId=${id}`, { method: 'POST' })
                .then(response => {
                    if(response.ok) carregarAba('Sugestoes');
                    else alert("Erro ao definir sugestão.");
                });
        }

        function sortearSugestao(periodo) {
            fetch(`/Admin/SortearSugestao?periodo=${periodo}`, { method: 'POST' })
                .then(response => {
                    if(response.ok) carregarAba('Sugestoes');
                    else alert("Erro ao sortear.");
                });
        }

        function toggleUsuariosInativos() {
            const mostrar = document.getElementById('chkMostrarInativos').checked;
            $("#perfilContent").html('<p style="color: white; text-align:center;">Carregando...</p>');
            $("#perfilContent").load(`/Admin/ObterUsuarios?mostrarInativos=${mostrar}`);
        }

        function alternarStatusUsuario(id, desativando) {
            const acao = desativando ? "desativar" : "reativar";
            
            perguntar(`Tem certeza que deseja ${acao} este usuário?`, function() {
                fetch(`/Admin/AlternarStatusUsuario/${id}`, { method: 'POST' })
                .then(async response => {
                    if (response.ok) {
                        toggleUsuariosInativos();
                    } else {
                        const msg = await response.text();
                        alert(msg || `Erro ao ${acao} o usuário.`);
                    }
                }).catch(() => alert("Erro crítico de conexão com o servidor."));
            });
        }

        // ========================================================
        // 10. FECHAR MODAIS CLICANDO FORA
        // ========================================================
        window.onclick = function (event) {
            const IDs = ['modalCadastro', 'modalLogin', 'modalRecuperarSenha', 'perfilModal', 'enderecoModal', 'customConfirmModal', 'itemCardapioModal'];
            IDs.forEach(id => {
                const el = document.getElementById(id);
                if (event.target == el && el != null) el.style.display = 'none';
            });
        }
    </script>
    
    @if (TempData["MensagemErroSistema"] != null)
    {
        <script>
            window.addEventListener('load', function () {
                // A utilização do JsonSerializer.Serialize previne o erro CS1012 do Razor e injeta de forma segura no Javascript
                alert(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["MensagemErroSistema"])));
            });
        </script>
    }
    }
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>