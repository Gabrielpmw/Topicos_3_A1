@model List<restaurante.ViewModels.ItemCardapioViewModel>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
    <h3 style="color: var(--gold); margin: 0;">Gerenciar Cardápio</h3>
    
    <div style="display: flex; gap: 12px; align-items: center;">
        <select id="filtroPratos" onchange="carregarAbaPratosFiltro(this.value)" style="padding: 8px; border-radius: 6px; background: #0f172a; color: white; border: 1px solid var(--gold); font-size: 0.85rem; cursor: pointer;">
            <option value="ativos">Apenas Ativos</option>
            <option value="inativos">Apenas Desativados</option>
            <option value="todos">Todos os Itens</option>
        </select>
        
        <button onclick="abrirModalItemCardapio()" class="btn-gold" style="padding: 8px 15px; font-size: 0.85rem;">+ Novo Item</button>
    </div>
</div>

@if (!Model.Any())
{
    <div style="text-align: center; padding: 40px; border: 1px dashed var(--border-color); border-radius: 10px;">
        <p style="color: var(--text-gray); margin: 0;">Nenhum item encontrado para este filtro.</p>
    </div>
}
else
{
    <div style="display: flex; flex-direction: column; gap: 12px;">
        @foreach (var item in Model)
        {
            <div style="background: var(--bg-input); padding: 18px; border-radius: 10px; border: 1px solid @(item.IsAtivo ? "var(--border-color)" : "#ef4444"); display: flex; justify-content: space-between; align-items: center; opacity: @(item.IsAtivo ? "1" : "0.7"); transition: 0.3s;">
                <div style="flex: 1; padding-right: 20px;">
                    <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 5px;">
                        <strong style="color: white; font-size: 1.1rem;">@item.Nome</strong>
                        
                        <span style="background: @(item.Periodo == 0 ? "#f59e0b" : "#3b82f6"); color: white; padding: 2px 8px; border-radius: 12px; font-size: 0.65rem; font-weight: bold; text-transform: uppercase;">
                            @(item.Periodo == 0 ? "Almoço" : "Jantar")
                        </span>

                        @if (!item.IsAtivo)
                        {
                            <span style="color: #ef4444; font-size: 0.75rem; font-weight: bold; text-transform: uppercase;">(Inativo)</span>
                        }
                    </div>
                    <p style="color: var(--text-gray); font-size: 0.85rem; margin: 0 0 8px 0; line-height: 1.4;">@item.Descricao</p>
                    <span style="color: var(--gold); font-weight: bold; font-size: 1.1rem;">R$ @item.PrecoBase.ToString("F2")</span>
                </div>

                <div style="display: flex; gap: 8px; align-items: center;">
                    @{
                        // Aqui tratamos tanto a lista de ingredientes quanto a URL da imagem para o JS não quebrar
                        var jsonIngredientes = "[" + string.Join(",", item.IngredientesIds) + "]";
                        var imgSegura = string.IsNullOrEmpty(item.ImagemUrl) ? "" : item.ImagemUrl.Replace("'", "\\'");
                    }
                    
                    <button onclick="abrirModalItemCardapio(@item.Id, '@item.Nome.Replace("'", "\\'")', '@item.Descricao.Replace("'", "\\'")', @item.PrecoBase.ToString("F2", System.Globalization.CultureInfo.InvariantCulture), @item.Periodo, '@imgSegura', '@jsonIngredientes')" class="btn-outline-gold" style="padding: 7px 12px; font-size: 0.75rem;">Editar</button>
                    
                    @if (item.IsAtivo)
                    {
                        <button onclick="confirmarTrocaStatusPrato(@item.Id, 'desativar')" style="background: rgba(239, 68, 68, 0.15); color: #ef4444; border: 1px solid #ef4444; padding: 7px 12px; border-radius: 6px; cursor: pointer; font-size: 0.75rem; font-weight: bold;">Desativar</button>
                    }
                    else
                    {
                        <button onclick="confirmarTrocaStatusPrato(@item.Id, 'ativar')" style="background: rgba(34, 197, 94, 0.15); color: #22c55e; border: 1px solid #22c55e; padding: 7px 12px; border-radius: 6px; cursor: pointer; font-size: 0.75rem; font-weight: bold;">Ativar</button>
                    }
                </div>
            </div>
        }
    </div>
}

<script>
    // Esse pequeno script interno garante que, se a página recarregar via AJAX,
    // o select lá no topo saiba qual filtro está sendo aplicado no momento.
    // Ele tenta ler o valor da URL ou do estado global do JS.
    (function() {
        const filtroAtual = window.ultimoFiltroAplicado || 'ativos';
        const select = document.getElementById('filtroPratos');
        if(select) select.value = filtroAtual;
    })();
</script>